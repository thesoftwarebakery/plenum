{
  "mappings": [
    {
      "request": {
        "method": "GET_OR_HEAD",
        "urlPathPattern": "/products(/[^/]+)?"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "jsonBody": {
          "method": "{{request.method}}",
          "path": "{{request.path}}"
        },
        "transformers": ["response-template"]
      }
    },
    {
      "request": {
        "method": "GET_OR_HEAD",
        "urlPath": "/internal/debug"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "jsonBody": {
          "env": "dev",
          "debug": true
        }
      }
    }
  ]
}
